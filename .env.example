# Copie ce fichier en ".env" pour tester l'agent en local.
# NE JAMAIS commiter le vrai fichier .env (il est ignoré par git).

# Clé API OpenRouter (gratuite) : https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx

# (Facultatif) Modèle prioritaire. Laisse VIDE : l'agent essaie automatiquement
# plusieurs modèles gratuits en cascade (gpt-oss-120b, gemma-4-31b, gpt-oss-20b...).
# OPENROUTER_MODEL=openai/gpt-oss-120b:free

# Clé API Chariow (pour synchroniser tes vrais produits et ventes)
# À créer dans app.chariow.com > Paramètres > Clés API.
CHARIOW_API_KEY=colle-ici-ta-cle-chariow
