# Copie ce fichier en ".env" pour tester l'agent en local.
# NE JAMAIS commiter le vrai fichier .env (il est ignoré par git).

# Clé API OpenRouter (gratuite) : https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxx

# (Facultatif) Modèle à utiliser. Laisse vide pour le modèle gratuit par défaut.
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
